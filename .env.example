# Copy to .env and fill in. On Vercel, set these in Project → Settings → Environment Variables.
OPENAI_API_KEY=sk-...

# Model used for screening. gpt-4o-mini = cheap & fast (good default).
# For the strictest, most accurate screening use gpt-4o.
OPENAI_MODEL=gpt-4o-mini

# Minimum overall score (0-100) required to be "recommended for shortlist".
# Higher = stricter. 75 is already strict; bump to 80-85 to be ruthless.
SHORTLIST_THRESHOLD=90

# Supabase (Postgres) — the data store (works on Vercel's serverless runtime).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
